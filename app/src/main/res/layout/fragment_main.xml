<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="COMPAÑÍAS DE VIDEOJUEGOS"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="12dp"
            android:letterSpacing="0.1" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Las tres grandes compañías que dominan la industria de las consolas:"
            android:textColor="#CCCCCC"
            android:textSize="16sp"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="24dp"
            android:justificationMode="inter_word" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E60012"> 

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#1E1E1E">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="NINTENDO"
                    android:textColor="#E60012"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="La compañía más veterana y centrada en la innovación y la creatividad. Su estrategia se basa en la 'Blue Ocean Strategy' (crear mercados nuevos en lugar de competir solo en potencia gráfica). Sus franquicias (Mario, Zelda, Pokémon) son las más valiosas del mundo."
                    android:textColor="@android:color/white"
                    android:textSize="15sp"
                    android:lineSpacingExtra="2dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:strokeWidth="1dp"
            app:strokeColor="#003791"> 

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#1E1E1E">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SONY (PLAYSTATION)"
                    android:textColor="#003791"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Se distingue por sus superproducciones narrativas (juegos con calidad cinematográfica) y un hardware potente. Han sabido cultivar una base de fans leal gracias a exclusivos como The Last of Us o God of War."
                    android:textColor="@android:color/white"
                    android:textSize="15sp"
                    android:lineSpacingExtra="2dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:strokeWidth="1dp"
            app:strokeColor="#107C10">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#1E1E1E">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="MICROSOFT (XBOX)"
                    android:textColor="#107C10"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ha cambiado el paradigma de la industria hacia el modelo de suscripción. Con Xbox Game Pass (el 'Netflix de los videojuegos'), su enfoque ya no es solo vender consolas, sino captar usuarios en cualquier dispositivo (PC, móvil, consola)."
                    android:textColor="@android:color/white"
                    android:textSize="15sp"
                    android:lineSpacingExtra="2dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <View android:layout_height="20dp" android:layout_width="match_parent"/>

    </LinearLayout>
</ScrollView>
