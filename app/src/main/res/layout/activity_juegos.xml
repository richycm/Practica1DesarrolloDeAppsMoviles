<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#B0BEC5">

    <TextView
        android:id="@+id/tvTituloSeccion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Juegos más representativos"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#263238"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <LinearLayout
        android:id="@+id/layoutButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvTituloSeccion">

        <Button
            android:id="@+id/btnVolverGeneraciones"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Generaciones"
            android:textAllCaps="false"
            android:backgroundTint="#2196F3"
            android:textColor="@android:color/white"
            app:cornerRadius="12dp" />

        <Button
            android:id="@+id/btnIrInicio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Ir al Inicio"
            android:textAllCaps="false"
            android:backgroundTint="#2196F3"
            android:textColor="@android:color/white"
            app:cornerRadius="12dp" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/layoutButtons"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nintendo"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#E60012"
                android:layout_marginBottom="8dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FFEBEE">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">
                    <ImageView
                        android:id="@+id/ivMario"
                        android:layout_width="80dp"
                        android:layout_height="110dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/mario_bros"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>
                    <TextView
                        android:id="@+id/tvMarioTitulo"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Super Mario Bros."
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#E60012"
                        android:layout_marginStart="12dp"
                        app:layout_constraintTop_toTopOf="@id/ivMario"
                        app:layout_constraintStart_toEndOf="@id/ivMario"
                        app:layout_constraintEnd_toEndOf="parent"/>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Salvó a la industria en 1983. Definió las bases del género de plataformas y es el mayor ícono cultural de los videojuegos."
                        android:textSize="12sp"
                        android:textColor="#455A64"
                        app:layout_constraintTop_toBottomOf="@id/tvMarioTitulo"
                        app:layout_constraintStart_toStartOf="@id/tvMarioTitulo"
                        app:layout_constraintEnd_toEndOf="parent"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FFFDE7">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">
                    <ImageView
                        android:id="@+id/ivZelda"
                        android:layout_width="80dp"
                        android:layout_height="110dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/zelda_link"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>
                    <TextView
                        android:id="@+id/tvZeldaTitulo"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="The Legend of Zelda"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#FBC02D"
                        android:layout_marginStart="12dp"
                        app:layout_constraintTop_toTopOf="@id/ivZelda"
                        app:layout_constraintStart_toEndOf="@id/ivZelda"
                        app:layout_constraintEnd_toEndOf="parent"/>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Introdujo la exploración no lineal y mundos abiertos. Fue el primer juego de consola en permitir guardar el progreso."
                        android:textSize="12sp"
                        android:textColor="#455A64"
                        app:layout_constraintTop_toBottomOf="@id/tvZeldaTitulo"
                        app:layout_constraintStart_toStartOf="@id/tvZeldaTitulo"
                        app:layout_constraintEnd_toEndOf="parent"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PlayStation"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#003791"
                android:layout_marginBottom="8dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#F44336">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">
                    <ImageView
                        android:id="@+id/ivGOW"
                        android:layout_width="80dp"
                        android:layout_height="110dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/kratos"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>
                    <TextView
                        android:id="@+id/tvGOWTitulo"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="God of War"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#003791"
                        android:layout_marginStart="12dp"
                        app:layout_constraintTop_toTopOf="@id/ivGOW"
                        app:layout_constraintStart_toEndOf="@id/ivGOW"
                        app:layout_constraintEnd_toEndOf="parent"/>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Redefinió los juegos de acción 'hack and slash' y posteriormente la narrativa cinematográfica en los videojuegos con un enfoque maduro."
                        android:textSize="12sp"
                        android:textColor="#455A64"
                        app:layout_constraintTop_toBottomOf="@id/tvGOWTitulo"
                        app:layout_constraintStart_toStartOf="@id/tvGOWTitulo"
                        app:layout_constraintEnd_toEndOf="parent"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#2196F3">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">
                    <ImageView
                        android:id="@+id/ivTLOU"
                        android:layout_width="80dp"
                        android:layout_height="110dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/last"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>
                    <TextView
                        android:id="@+id/tvTLOUTitulo"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="The Last of Us"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#2E7D32"
                        android:layout_marginStart="12dp"
                        app:layout_constraintTop_toTopOf="@id/ivTLOU"
                        app:layout_constraintStart_toEndOf="@id/ivTLOU"
                        app:layout_constraintEnd_toEndOf="parent"/>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Elevó la narrativa y el desarrollo de personajes a niveles cinematográficos, ganando cientos de premios al juego del año."
                        android:textSize="12sp"
                        android:textColor="#455A64"
                        app:layout_constraintTop_toBottomOf="@id/tvTLOUTitulo"
                        app:layout_constraintStart_toStartOf="@id/tvTLOUTitulo"
                        app:layout_constraintEnd_toEndOf="parent"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Xbox"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#107C10"
                android:layout_marginBottom="8dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#23A82E">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">
                    <ImageView
                        android:id="@+id/ivHalo"
                        android:layout_width="80dp"
                        android:layout_height="110dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/halo"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>
                    <TextView
                        android:id="@+id/tvHaloTitulo"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Halo: Combat Evolved"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#107C10"
                        android:layout_marginStart="12dp"
                        app:layout_constraintTop_toTopOf="@id/ivHalo"
                        app:layout_constraintStart_toEndOf="@id/ivHalo"
                        app:layout_constraintEnd_toEndOf="parent"/>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Representó la evolución de los FPS en consolas. Fue el pilar que estableció a Xbox como una potencia en el gaming."
                        android:textSize="12sp"
                        android:textColor="#3F51B5"
                        app:layout_constraintTop_toBottomOf="@id/tvHaloTitulo"
                        app:layout_constraintStart_toStartOf="@id/tvHaloTitulo"
                        app:layout_constraintEnd_toEndOf="parent"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#F44336">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">
                    <ImageView
                        android:id="@+id/ivGears"
                        android:layout_width="80dp"
                        android:layout_height="110dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/gears"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>
                    <TextView
                        android:id="@+id/tvGearsTitulo"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Gears of War"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#212121"
                        android:layout_marginStart="12dp"
                        app:layout_constraintTop_toTopOf="@id/ivGears"
                        app:layout_constraintStart_toEndOf="@id/ivGears"
                        app:layout_constraintEnd_toEndOf="parent"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>